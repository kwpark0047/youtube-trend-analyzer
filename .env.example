# YouTube Data API v3
# YouTube API 키를 여기에 입력하세요
# 발급 방법: https://console.cloud.google.com/ → YouTube Data API v3 활성화 → 인증 정보 → API 키
NEXT_PUBLIC_YOUTUBE_API_KEY=

# Supabase 설정
# Supabase 프로젝트에서 확인할 수 있습니다: https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 선택사항: Cloudflare Workers 배포 시 사용
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
